{
  "run": {
    "virtual_users": 2,
    "iterations_per_user": 1,
    "max_workers": 2,
    "ramp_up_seconds": 2
  },
  "context": {
    "base_url": "https://dsapi.thelocal.co.in",
    "doctor_email": "{{doctor_email_local}}.{{run_email_suffix}}@example.com",
    "doctor_mobile": "{{run_mobile}}",
    "doctor_password": "AnanyaReddy@2026",
    "doctor_fullname": "{{doctor_fullname}}",
    "medical_council_board": "Andhra Pradesh Medical Council",
    "registration_number": "{{registration_number}}",
    "specialization_id": "MS03",
    "sub_specialization_id": "SS01",
    "additional_specialization_id": "AS01",
    "short_bio": "Interventional cardiologist focused on preventive and critical cardiac care.",
    "years_of_experience": 12,
    "date_of_birth": "1988-09-17",
    "gender": "Female",
    "open_to_referrals": "Y",
    "expert_opinions": "Y",
    "medical_id_url": "https://example.com/docs/medical-id.pdf",
    "profile_photo_url": "https://acintyotech-public.s3.ap-south-1.amazonaws.com/assets/e04a8228-ccee-4794-95e3-3d2a6a19474b.jpg",
    "cover_photo_url": "https://acintyotech-public.s3.ap-south-1.amazonaws.com/assets/e04a8228-ccee-4794-95e3-3d2a6a19474b.jpg",
    "company_name": "KIMS-Vijayawada Multispeciality Hospital",
    "interest_1": "MS03",
    "interest_2": "Thoracic Surgery"
  },
  "workflows": [
    {
      "name": "Referral Auth + Master Data",
      "steps": [
        {
          "name": "Doctor SignUp",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/auth/doctor/signUp",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Content-Type": "application/json"
          },
          "json": {
            "medicalCouncilBoard": "{{medical_council_board}}",
            "registrationNumber": "{{registration_number}}",
            "fullname": "{{doctor_fullname}}",
            "specializationId": "{{specialization_id}}",
            "subSpecializationId": "{{sub_specialization_id}}",
            "additionalSpecializationId": "{{additional_specialization_id}}",
            "shortBio": "{{short_bio}}",
            "yearsOfExperience": "{{years_of_experience}}",
            "dateOfBirth": "{{date_of_birth}}",
            "email": "{{doctor_email}}",
            "mobileNumber": "{{doctor_mobile}}",
            "gender": "{{gender}}",
            "rawPassword": "{{doctor_password}}",
            "password": "{{doctor_password}}",
            "pazzword": "{{doctor_password}}",
            "experience": [
              {
                "companyId": "{{company_id}}",
                "companyName": "{{company_name}}",
                "jobTitle": "Senior Cardiologist",
                "currentlyWorking": "Y",
                "startDate": "2015-06-01"
              }
            ],
            "medicalIdUrl": "{{medical_id_url}}",
            "openToReferrals": "{{open_to_referrals}}",
            "expertOpinions": "{{expert_opinions}}",
            "consultationMode": [
              "IN_PERSON",
              "TELEMEDICINE"
            ],
            "profilePhotoId": "{{profile_photo_url}}",
            "coverPhotoId": "{{cover_photo_url}}",
            "interested": [
              "{{interest_1}}",
              "{{interest_2}}"
            ]
          },
          "required_fields": [
            "json.medicalCouncilBoard",
            "json.registrationNumber",
            "json.fullname",
            "json.specializationId",
            "json.shortBio",
            "json.yearsOfExperience",
            "json.dateOfBirth",
            "json.email",
            "json.mobileNumber",
            "json.gender",
            "json.password",
            "json.experience",
            "json.experience.0.companyId",
            "json.experience.0.companyName",
            "json.experience.0.jobTitle",
            "json.experience.0.currentlyWorking",
            "json.experience.0.startDate",
            "json.openToReferrals",
            "json.expertOpinions",
            "json.consultationMode"
          ],
          "timeout_seconds": 20,
          "retries": 3,
          "retry_delay_seconds": 1.0,
          "expected": {
            "status_code": 201,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "doctor_id": "data.id",
            "doctor_access_token": "data.token",
            "doctor_refresh_token": "data.refreshToken"
          }
        },
        {
          "name": "Doctor SignIn",
          "depends_on": "Doctor SignUp",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/auth/doctor/signIn",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Content-Type": "application/json"
          },
          "json": {
            "email": "{{doctor_email}}",
            "password": "{{doctor_password}}",
            "fcmToken": ""
          },
          "required_fields": [
            "json.email",
            "json.password"
          ],
          "timeout_seconds": 20,
          "retries": 3,
          "retry_delay_seconds": 2.0,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "signin_doctor_id": "data.id",
            "signin_access_token": "data.token",
            "signin_refresh_token": "data.refreshToken"
          },
          "retry_on_status_codes": [
            401,
            408,
            425,
            429,
            500,
            502,
            503,
            504
          ]
        },
        {
          "name": "Update Intro",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/update/intro",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "fullname": "{{doctor_fullname}}",
            "headLine": "{{doctor_fullname}} - {{specialization_name}}",
            "additionalName": "{{doctor_last_name}}",
            "country": "India",
            "city": "Hyderabad"
          },
          "required_fields": [
            "json.doctorId",
            "json.fullname",
            "json.headLine",
            "json.country",
            "json.city"
          ],
          "timeout_seconds": 10,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true,
              "data.success": true
            }
          }
        },
        {
          "name": "Get All Main Specializations",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/master/specializations/search",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "specializationType": "MAIN"
          },
          "required_fields": [
            "json.specializationType"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Get All Sub Specializations",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/master/specializations/search",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "specializationType": "SUB"
          },
          "required_fields": [
            "json.specializationType"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Get All Doctors",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/get/all/doctors",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {},
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Get Doctor By Id",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/get/by-id",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "id": "{{peer_doctor_id}}"
          },
          "required_fields": [
            "json.id"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        }
      ]
    },
    {
      "name": "Referral CRUD",
      "steps": [
        {
          "name": "Create Referral",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/create-referral",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "creatorId": "{{signin_doctor_id}}",
            "patientName": "Test Patient Kumar",
            "patientAge": 45,
            "patientGender": "MALE",
            "patientContactNumber": "9876543210",
            "patientEmail": "testpatient.kumar@example.com",
            "concern": "Chest pain and shortness of breath for automated testing",
            "specializationId": "MS03",
            "subSpecializationId": "SS01",
            "reportUrl": "https://example.com/reports/test-ecg-report.pdf",
            "referralPoints": 100,
            "priorityType": "ROUTINE",
            "followUpFlag": "N",
            "listOfDoctorIds": [
              "{{peer_doctor_id}}"
            ],
            "specializationName": "Cardiology",
            "subSpecializationName": "Interventional Cardiology",
            "specificCondition": "Suspected Acute Coronary Syndrome"
          },
          "required_fields": [
            "json.creatorId",
            "json.patientName",
            "json.specializationId",
            "json.listOfDoctorIds",
            "json.listOfDoctorIds.0",
            "json.priorityType"
          ],
          "timeout_seconds": 20,
          "retries": 2,
          "retry_delay_seconds": 1.0,
          "expected": {
            "status_code": 201,
            "json_path_equals": {
              "success": true
            },
            "body_contains": [
              "Referral Saved"
            ]
          }
        },
        {
          "name": "Get All Referred By Creator",
          "depends_on": "Create Referral",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/getAllReferred/byCreator",
          "params": {
            "page": "0",
            "size": "10"
          },
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "creatorId": "{{signin_doctor_id}}"
          },
          "required_fields": [
            "json.creatorId"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "referral_id": "data.content.0.id"
          }
        },
        {
          "name": "Get Referral By Id",
          "depends_on": "Get All Referred By Creator",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/getByReferalId",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "referralId": "{{referral_id}}"
          },
          "required_fields": [
            "json.referralId"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "doctor_response_id": "data.doctorResponseDtos.0.id"
          }
        },
        {
          "name": "Total Referred Patients PENDING",
          "depends_on": "Create Referral",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/total-referred/patients",
          "params": {
            "page": "0",
            "size": "10"
          },
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "creatorId": "{{signin_doctor_id}}",
            "status": "PENDING"
          },
          "required_fields": [
            "json.creatorId",
            "json.status"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Update Referral",
          "depends_on": "Get Referral By Id",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/update-referral",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "refferalId": "{{referral_id}}",
            "creatorId": "{{signin_doctor_id}}",
            "patientName": "Updated Test Patient Kumar",
            "patientAge": 46,
            "patientGender": "MALE",
            "patientContactNumber": "9876543210",
            "patientEmail": "testpatient.kumar@example.com",
            "concern": "Updated: Chest pain, shortness of breath, and dizziness",
            "specializationId": "MS03",
            "subSpecializationId": "SS01",
            "reportUrl": "https://example.com/reports/updated-ecg-report.pdf",
            "referralPoints": 120,
            "priorityType": "EMERGENCY",
            "followUpFlag": "Y",
            "listOfDoctorIds": [
              "{{peer_doctor_id}}"
            ]
          },
          "required_fields": [
            "json.refferalId",
            "json.creatorId",
            "json.patientName"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 201,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Send Reminder",
          "depends_on": "Get Referral By Id",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/send-reminder",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "creatorId": "{{peer_doctor_id}}"
          },
          "required_fields": [
            "json.creatorId"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Referred Count",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/referredCount-view",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}"
          },
          "required_fields": [
            "json.doctorId"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Received Count",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/receivedCount-view",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}"
          },
          "required_fields": [
            "json.doctorId"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Frequently Referred Doctor",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/frequenty-referred-doctor",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {},
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        }
      ]
    },
    {
      "name": "Referred Doctor Accept Flow",
      "steps": [
        {
          "name": "Update Status Accept",
          "depends_on": "Get Referral By Id",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/doctor/update-status",
          "headers": {
            "Authorization": "Bearer {{peer_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{peer_doctor_id}}",
            "status": "ACCEPTED",
            "patientId": "{{referral_id}}"
          },
          "required_fields": [
            "json.doctorId",
            "json.status",
            "json.patientId"
          ],
          "timeout_seconds": 20,
          "retries": 2,
          "retry_delay_seconds": 1.0,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Update Patient Status Admitted",
          "depends_on": "Update Status Accept",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/doctor/update/patient-status",
          "headers": {
            "Authorization": "Bearer {{peer_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{peer_doctor_id}}",
            "patientId": "{{referral_id}}",
            "visitType": "ADMITTED"
          },
          "required_fields": [
            "json.doctorId",
            "json.patientId",
            "json.visitType"
          ],
          "timeout_seconds": 20,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Total Received Patients",
          "depends_on": "Update Status Accept",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/total-received/patients",
          "params": {
            "page": "0",
            "size": "10"
          },
          "headers": {
            "Authorization": "Bearer {{peer_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "creatorId": "{{peer_doctor_id}}",
            "status": "ACCEPTED"
          },
          "required_fields": [
            "json.creatorId"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Total Referred Patients Accepted",
          "depends_on": "Update Status Accept",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/total-referred/patients",
          "params": {
            "page": "0",
            "size": "10"
          },
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "creatorId": "{{signin_doctor_id}}",
            "status": "ACCEPTED"
          },
          "required_fields": [
            "json.creatorId",
            "json.status"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        }
      ]
    },
    {
      "name": "Credit Point Tracking",
      "steps": [
        {
          "name": "Total Credit Points Header",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/creditHeader",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}"
          },
