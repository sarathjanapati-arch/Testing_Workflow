              "success": true
            }
          }
        },
        {
          "name": "Get Credit Points By Sender",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/creditPoint/getBySender",
          "params": {
            "page": "0",
            "size": "10"
          },
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "senderId": "{{signin_doctor_id}}"
          },
          "required_fields": [
