          "params": {
            "page": "0",
            "size": "10"
          },
          "headers": {
            "Authorization": "Bearer {{peer_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "receiverId": "{{peer_doctor_id}}"
          },
          "required_fields": [
            "json.receiverId"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Update Credit Status By Sender",
          "depends_on": "Update Patient Status Admitted",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/creditPoint/update-status/bySender",
          "headers": {
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "senderId": "{{signin_doctor_id}}",
            "creditStatus": "SENT",
            "referralId": "{{referral_id}}"
          },
          "required_fields": [
            "json.senderId",
            "json.creditStatus",
            "json.referralId"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        },
        {
          "name": "Update Credit Status By Receiver",
          "depends_on": "Update Credit Status By Sender",
          "method": "POST",
          "url": "{{base_url}}/dc/api-referral/v1/creditPoint/update-status/byReceiver",
          "headers": {
            "Authorization": "Bearer {{peer_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "receiverId": "{{peer_doctor_id}}",
            "creditStatus": "ACCEPTED",
            "referralId": "{{referral_id}}"
          },
          "required_fields": [
            "json.receiverId",
            "json.creditStatus",
            "json.referralId"
          ],
          "timeout_seconds": 15,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          }
        }
      ]
    },
    {
      "name": "Cancel & Delete",
      "steps": [
        {
          "name": "Create Cancel Test Referral",
