  "workflows": [
    {
      "name": "Doctor Auth + Profile",
      "steps": [
        {
          "name": "Doctor SignUp",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/auth/doctor/signUp",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Content-Type": "application/json"
          },
          "json": {
            "medicalCouncilBoard": "{{medical_council_board}}",
            "registrationNumber": "{{registration_number}}",
            "fullname": "{{doctor_fullname}}",
            "specializationId": "{{specialization_id}}",
            "subSpecializationId": "{{sub_specialization_id}}",
            "shortBio": "{{short_bio}}",
            "yearsOfExperience": "{{years_of_experience}}",
            "dateOfBirth": "{{date_of_birth}}",
            "email": "{{doctor_email}}",
            "mobileNumber": "{{doctor_mobile}}",
            "gender": "{{gender}}",
            "rawPassword": "{{doctor_password}}",
            "password": "{{doctor_password}}",
            "pazzword": "{{doctor_password}}",
            "experience": [
              {
                "companyId": "{{company_id}}",
                "companyName": "{{company_name}}",
                "jobTitle": "Senior Cardiologist",
                "currentlyWorking": "Y",
                "startDate": "2015-06-01"
              }
            ],
            "medicalIdUrl": "{{medical_id_url}}",
            "openToReferrals": "{{open_to_referrals}}",
            "expertOpinions": "{{expert_opinions}}",
            "consultationMode": [
              "IN_PERSON",
              "TELEMEDICINE"
            ],
            "profilePhotoId": "{{profile_photo_url}}",
            "coverPhotoId": "{{cover_photo_url}}",
            "interested": [
              "{{interest_1}}",
              "{{interest_2}}"
            ]
          },
          "required_fields": [
            "json.medicalCouncilBoard",
            "json.registrationNumber",
            "json.fullname",
            "json.specializationId",
            "json.shortBio",
            "json.yearsOfExperience",
            "json.dateOfBirth",
            "json.email",
            "json.mobileNumber",
            "json.gender",
            "json.password",
            "json.experience",
            "json.experience.0.companyId",
            "json.experience.0.companyName",
            "json.experience.0.jobTitle",
            "json.experience.0.currentlyWorking",
            "json.experience.0.startDate",
            "json.openToReferrals",
            "json.expertOpinions",
            "json.consultationMode"
          ],
          "timeout_seconds": 20,
          "retries": 3,
          "retry_delay_seconds": 1.0,
          "expected": {
            "status_code": 201,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "doctor_id": "data.id",
            "doctor_access_token": "data.token",
            "doctor_refresh_token": "data.refreshToken",
            "account_verified": "data.accountVerified"
          }
        },
        {
          "name": "Doctor SignIn",
          "depends_on": "Doctor SignUp",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/auth/doctor/signIn",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Content-Type": "application/json"
          },
          "json": {
            "email": "{{doctor_email}}",
            "password": "{{doctor_password}}",
            "fcmToken": ""
          },
          "required_fields": [
            "json.email",
            "json.password"
          ],
          "timeout_seconds": 20,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "signin_doctor_id": "data.id",
            "signin_access_token": "data.token",
            "signin_refresh_token": "data.refreshToken"
          },
          "retries": 5,
          "retry_delay_seconds": 1.0,
          "retry_on_status_codes": [
            401,
            408,
            425,
            429,
            500,
            502,
            503,
            504
          ]
        },
        {
          "name": "Update Intro",
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/update/intro",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "fullname": "{{doctor_fullname}}",
            "headLine": "{{doctor_fullname}} - {{specialization_name}}",
            "additionalName": "{{doctor_last_name}}",
            "country": "India",
            "city": "Hyderabad"
          },
          "required_fields": [
            "json.doctorId",
            "json.fullname",
            "json.headLine",
            "json.country",
            "json.city"
          ],
          "timeout_seconds": 10,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true,
              "data.success": true
            }
          }
        },
        {
          "name": "Add Experience",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/add/experience",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "experience": {
              "companyId": "{{company_id}}",
              "companyName": "{{company_name}}",
              "jobTitle": "Senior Cardiologist",
              "currentlyWorking": "Y",
              "startDate": "2018-01-01"
            }
          },
          "required_fields": [
            "json.doctorId",
            "json.experience.companyId",
            "json.experience.companyName",
            "json.experience.jobTitle",
            "json.experience.currentlyWorking",
            "json.experience.startDate"
          ],
          "save": {
            "experience_id": "data.0.id"
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Update Experience",
          "enabled": true,
          "depends_on": "Add Experience",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/update/experience",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "experienceId": "{{experience_id}}",
            "experience": {
              "companyId": "{{company_id}}",
              "companyName": "{{company_name}}",
              "jobTitle": "Consultant Cardiologist",
              "currentlyWorking": "Y",
              "startDate": "2018-01-01"
            }
          },
          "required_fields": [
            "json.doctorId",
            "json.experienceId",
            "json.experience.companyId",
            "json.experience.companyName",
            "json.experience.jobTitle",
            "json.experience.currentlyWorking",
            "json.experience.startDate"
          ],
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Add Education",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/add/education",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "education": {
              "degreeName": "MD",
              "schoolName": "Andhra Medical College",
              "fieldName": "Cardiology",
              "startDate": "2009-06-01",
              "endDate": "2012-05-31",
              "grade": "A"
            }
          },
          "required_fields": [
            "json.doctorId",
            "json.education.degreeName",
            "json.education.schoolName",
            "json.education.fieldName",
            "json.education.startDate",
            "json.education.endDate"
          ],
          "save": {
            "education_id": "data.0.educationId"
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Update Education",
          "enabled": true,
          "depends_on": "Add Education",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/update/education",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "educationId": "{{education_id}}",
            "education": {
              "degreeName": "MD",
              "schoolName": "Updated Andhra Medical College",
              "fieldName": "Cardiology",
              "startDate": "2009-06-01",
              "endDate": "2012-05-31",
              "grade": "A+"
            }
          },
          "required_fields": [
            "json.doctorId",
            "json.educationId",
            "json.education.degreeName",
            "json.education.schoolName",
            "json.education.fieldName",
            "json.education.startDate",
            "json.education.endDate"
          ],
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Add Language",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/add/language",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "language": "English",
            "proficiencyLevel": "PROFESSIONAL"
          },
          "required_fields": [
            "json.doctorId",
            "json.language",
            "json.proficiencyLevel"
          ],
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Add Skill",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/add/skill",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "skillName": "Coronary Angioplasty",
            "sources": []
          },
          "required_fields": [
            "json.doctorId",
            "json.skillName"
          ],
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Update Cover Photo",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/update/cover/image",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "coverPhotoId": "{{cover_photo_url}}"
          },
          "required_fields": [
            "json.doctorId",
            "json.coverPhotoId"
          ],
          "expected": {
            "status_code": 200
          }
        }
      ]
    },
    {
      "name": "Post Service + Network",
      "steps": [
        {
          "name": "Doctor Search",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/get/doctor/profiles/search",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{doctor_search_payload}}",
          "required_fields": [
            "json.userId"
          ],
          "retries": 2,
          "retry_delay_seconds": 0.2,
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Create Post",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/create-post",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{create_post_payload}}",
          "required_fields": [
            "json.authorId",
            "json.content",
            "json.visibility"
          ],
          "expected": {
            "status_code": 201
          }
        },
        {
          "name": "Get Home Feed",
          "enabled": true,
          "depends_on": "Create Post",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/get/user/home/feed",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{home_feed_payload}}",
          "required_fields": [
            "json.id"
          ],
          "retries": 2,
          "retry_delay_seconds": 1.0,
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Get Profile Posts",
          "enabled": true,
          "depends_on": "Create Post",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/get/profile/posts",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{profile_posts_payload}}",
          "required_fields": [
            "json.id"
          ],
          "retries": 3,
          "retry_delay_seconds": 1.0,
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Post Like",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/posts/reactions",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{post_reaction_payload}}",
          "required_fields": [
            "json.postId",
            "json.userId",
            "json.reactionType"
          ],
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Update Post",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/update-post",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{update_post_payload}}",
          "required_fields": [
            "json.authorId",
            "json.postId",
            "json.content",
            "json.visibility"
          ],
          "expected": {
            "status_code": 201
          }
        },
        {
          "name": "Get Likes",
          "enabled": true,
          "depends_on": "Post Like",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/post/likes",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{post_likes_payload}}",
          "required_fields": [
            "json.viewerId",
            "json.postId",
            "json.size",
            "json.reactionType"
          ],
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Home Feed Using Cursor",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/get/home/feed",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
