{
  "run": {
    "virtual_users": 3,
    "iterations_per_user": 1,
    "max_workers": 3
  },
  "context": {
    "base_url": "https://dsapi.thelocal.co.in",
    "base_url_4040": "https://dsapi.thelocal.co.in:4040",
    "api_key": "ACIN-SDGESDFYRGFSDF",
    "doctor_email": "{{doctor_email_local}}+{{run_email_suffix}}@example.com",
    "doctor_mobile": "{{run_mobile}}",
    "doctor_password": "AnanyaReddy@2026",
    "doctor_fullname": "{{doctor_fullname}}",
    "medical_council_board": "Andhra Pradesh Medical Council",
    "registration_number": "{{registration_number}}",
    "specialization_id": "MS03",
    "sub_specialization_id": "SS01",
    "additional_specialization_id": "AS01",
    "short_bio": "Interventional cardiologist focused on preventive and critical cardiac care.",
    "years_of_experience": 12,
    "date_of_birth": "1988-09-17",
    "gender": "Female",
    "open_to_referrals": "Y",
    "expert_opinions": "Y",
    "medical_id_url": "https://example.com/docs/medical-id-ananya-reddy.pdf",
    "profile_photo_url": "https://example.com/images/ananya-reddy-profile.jpg",
    "cover_photo_url": "https://example.com/images/ananya-reddy-cover.jpg",
    "company_name": "KIMS-Vijayawada Multispeciality Hospital",
    "interest_1": "MS03",
    "interest_2": "Thoracic Surgery"
  },
  "workflows": [
    {
      "name": "Doctor Signup Sample",
      "steps": [
        {
          "name": "Doctor SignUp",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/auth/doctor/signUp",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Content-Type": "application/json"
          },
          "json": {
            "medicalCouncilBoard": "{{medical_council_board}}",
            "registrationNumber": "{{registration_number}}",
            "fullname": "{{doctor_fullname}}",
            "specializationId": "{{specialization_id}}",
            "shortBio": "{{short_bio}}",
            "yearsOfExperience": "{{years_of_experience}}",
            "dateOfBirth": "{{date_of_birth}}",
            "email": "{{doctor_email}}",
            "mobileNumber": "{{doctor_mobile}}",
            "gender": "{{gender}}",
            "rawPassword": "{{doctor_password}}",
            "password": "{{doctor_password}}",
            "pazzword": "{{doctor_password}}",
            "experience": [
              {
                "companyId": "{{company_id}}",
                "companyName": "{{company_name}}",
                "jobTitle": "Senior Cardiologist",
                "currentlyWorking": "Y",
                "startDate": "2015-06-01"
              }
            ],
            "medicalIdUrl": "{{medical_id_url}}",
            "openToReferrals": "{{open_to_referrals}}",
            "expertOpinions": "{{expert_opinions}}",
            "consultationMode": [
              "IN_PERSON",
              "TELEMEDICINE"
            ],
            "profilePhotoId": "{{profile_photo_url}}",
            "coverPhotoId": "{{cover_photo_url}}",
            "interested": [
              "{{interest_1}}",
              "{{interest_2}}"
            ]
          },
          "timeout_seconds": 20,
          "retries": 0,
          "retry_delay_seconds": 0.5,
          "expected": {
            "status_code": 201,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "doctor_id": "data.id",
            "doctor_access_token": "data.token",
            "doctor_refresh_token": "data.refreshToken",
            "account_verified": "data.accountVerified"
          }
        },
        {
          "name": "Doctor SignIn",
          "depends_on": "Doctor SignUp",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/auth/doctor/signIn",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Content-Type": "application/json"
          },
          "json": {
            "email": "{{doctor_email}}",
            "password": "{{doctor_password}}",
            "fcmToken": ""
          },
          "timeout_seconds": 20,
          "retries": 0,
          "retry_delay_seconds": 0.5,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "signin_doctor_id": "data.id",
            "signin_access_token": "data.token",
            "signin_refresh_token": "data.refreshToken"
          }
        },
        {
          "name": "Add Experience",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/add/experience",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "experience": {
              "companyId": "{{company_id}}",
              "companyName": "{{company_name}}",
              "jobTitle": "Senior Cardiologist",
              "currentlyWorking": "Y",
              "startDate": "2018-01-01"
            }
          },
          "save": {
            "experience_id": "data.0.id"
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Update Experience",
          "enabled": true,
          "depends_on": "Add Experience",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/update/experience",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "experienceId": "{{experience_id}}",
            "experience": {
              "companyId": "{{company_id}}",
              "companyName": "{{company_name}}",
              "jobTitle": "Consultant Cardiologist",
              "currentlyWorking": "Y",
              "startDate": "2018-01-01"
            }
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Add Education",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/add/education",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "education": {
              "degreeName": "MD",
              "schoolName": "Andhra Medical College",
              "fieldName": "Cardiology",
              "startDate": "2009-06-01",
              "endDate": "2012-05-31",
              "grade": "A"
            }
          },
          "save": {
            "education_id": "data.0.educationId"
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Update Education",
          "enabled": true,
          "depends_on": "Add Education",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/update/education",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "educationId": "{{education_id}}",
            "education": {
              "degreeName": "MD",
              "schoolName": "Updated Andhra Medical College",
              "fieldName": "Cardiology",
              "startDate": "2009-06-01",
              "endDate": "2012-05-31",
              "grade": "A+"
            }
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Add Language",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/add/language",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "language": "English",
            "proficiencyLevel": "PROFESSIONAL"
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Add Skill",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/add/skill",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "skillName": "Coronary Angioplasty",
            "sources": []
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Update Cover Photo",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/update/cover/image",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": {
            "doctorId": "{{signin_doctor_id}}",
            "coverPhotoId": "{{cover_photo_url}}"
          },
          "expected": {
            "status_code": 200
          }
        }
      ]
    }
  ]
}
