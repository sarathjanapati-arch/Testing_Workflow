{
  "context": {
    "base_url": "https://api.your-doctor-app.com",
    "doctor_email": "doctor+{{run_timestamp}}@example.com",
    "doctor_password": "StrongPass@123",
    "doctor_name": "Dr. Workflow Tester",
    "specialization": "Cardiology"
  },
  "workflows": [
    {
      "name": "Doctor Registration",
      "steps": [
        {
          "name": "Register Doctor",
          "method": "POST",
          "url": "{{base_url}}/auth/register",
          "json": {
            "name": "{{doctor_name}}",
            "email": "{{doctor_email}}",
            "password": "{{doctor_password}}",
            "specialization": "{{specialization}}"
          },
          "expected": {
            "status_code": 201,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "doctor_id": "data.user.id"
          }
        },
        {
          "name": "Login Doctor",
          "method": "POST",
          "url": "{{base_url}}/auth/login",
          "json": {
            "email": "{{doctor_email}}",
            "password": "{{doctor_password}}"
          },
          "expected": {
            "status_code": 200
          },
          "save": {
            "access_token": "data.token"
          }
        }
      ]
    },
    {
      "name": "Doctor Posting",
      "steps": [
        {
          "name": "Create Post",
          "method": "POST",
          "url": "{{base_url}}/posts",
          "headers": {
            "Authorization": "Bearer {{access_token}}"
          },
          "json": {
            "content": "Clinical insight posted at {{run_timestamp}}",
            "visibility": "public"
          },
          "expected": {
            "status_code": 201
          },
          "save": {
            "post_id": "data.post.id"
          }
        }
      ]
    },
    {
      "name": "Doctor Viewing",
      "steps": [
        {
          "name": "View Feed",
          "method": "GET",
          "url": "{{base_url}}/feed",
          "headers": {
            "Authorization": "Bearer {{access_token}}"
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "View Post Details",
          "method": "GET",
          "url": "{{base_url}}/posts/{{post_id}}",
          "headers": {
            "Authorization": "Bearer {{access_token}}"
          },
          "expected": {
            "status_code": 200
          }
        }
      ]
    },
    {
      "name": "Others - Add Your Custom Flows",
      "steps": [
        {
          "name": "Sample Custom Step",
          "method": "GET",
          "url": "{{base_url}}/your/custom/endpoint",
          "headers": {
            "Authorization": "Bearer {{access_token}}"
          },
          "expected": {
            "status_code": 200
          }
        }
      ]
    }
  ]
}