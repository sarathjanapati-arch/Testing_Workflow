    },
    "detail_post_payload": {
      "viewerId": "{{known_viewer_id}}",
      "postId": "{{known_detail_post_id}}"
    }
  },
  "workflows": [
    {
      "name": "Doctor Auth For Post Service",
      "steps": [
        {
          "name": "Doctor SignUp",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/auth/doctor/signUp",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Content-Type": "application/json"
          },
          "json": {
            "medicalCouncilBoard": "{{medical_council_board}}",
            "registrationNumber": "{{registration_number}}",
            "fullname": "{{doctor_fullname}}",
            "specializationId": "{{specialization_id}}",
            "shortBio": "{{short_bio}}",
            "yearsOfExperience": "{{years_of_experience}}",
            "dateOfBirth": "{{date_of_birth}}",
            "email": "{{doctor_email}}",
            "mobileNumber": "{{doctor_mobile}}",
            "gender": "{{gender}}",
            "rawPassword": "{{doctor_password}}",
            "password": "{{doctor_password}}",
            "pazzword": "{{doctor_password}}",
            "experience": [
              {
                "companyId": "{{company_id}}",
                "companyName": "{{company_name}}",
                "jobTitle": "Senior Cardiologist",
                "currentlyWorking": "Y",
                "startDate": "2015-06-01"
              }
            ],
            "medicalIdUrl": "{{medical_id_url}}",
            "openToReferrals": "{{open_to_referrals}}",
            "expertOpinions": "{{expert_opinions}}",
            "consultationMode": [
              "IN_PERSON",
              "TELEMEDICINE"
            ],
            "profilePhotoId": "{{profile_photo_url}}",
            "coverPhotoId": "{{cover_photo_url}}",
            "interested": [
              "{{interest_1}}",
              "{{interest_2}}"
            ]
          },
          "timeout_seconds": 20,
          "expected": {
            "status_code": 201,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "doctor_id": "data.id"
          }
        },
        {
          "name": "Doctor SignIn",
          "depends_on": "Doctor SignUp",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/auth/doctor/signIn",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Content-Type": "application/json"
          },
          "json": {
            "email": "{{doctor_email}}",
            "password": "{{doctor_password}}",
            "fcmToken": ""
          },
          "timeout_seconds": 20,
          "expected": {
            "status_code": 200,
            "json_path_equals": {
              "success": true
            }
          },
          "save": {
            "signin_doctor_id": "data.id",
            "signin_access_token": "data.token",
            "signin_refresh_token": "data.refreshToken"
          }
        }
      ]
    },
    {
      "name": "Post Service",
      "steps": [
        {
          "name": "Doctor Search",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-auth/v1/doctor/get/doctor/profiles/search",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{doctor_search_payload}}",
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Create Post",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/create-post",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{create_post_payload}}",
          "expected": {
            "status_code": 201
          }
        },
        {
          "name": "Get Home Feed",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/get/user/home/feed",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{home_feed_payload}}",
          "retries": 2,
          "retry_delay_seconds": 1.0,
          "save": {
            "post_id": [
              "data.0.postId",
              "data.0.id"
            ],
            "feed_cursor": [
              "data.nextCursor",
              "data.cursor",
              "data.nextPageCursor",
              "nextCursor",
              "cursor"
            ]
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Get Profile Posts",
          "enabled": true,
          "depends_on": "Create Post",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/get/profile/posts",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{profile_posts_payload}}",
          "retries": 3,
          "retry_delay_seconds": 1.0,
          "save": {
            "post_id": [
              "data.0.postId",
              "data.0.id"
            ]
          },
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Post Like",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/posts/reactions",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{post_reaction_payload}}",
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Update Post",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/update-post",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{update_post_payload}}",
          "expected": {
            "status_code": 201
          }
        },
        {
          "name": "Get Likes",
          "enabled": true,
          "depends_on": "Post Like",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/post/likes",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{post_likes_payload}}",
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Send Connection Request",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-network/v1/friend/request",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{friend_request_payload}}",
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Home Feed Using Cursor",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/get/home/feed",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{home_feed_cursor_payload}}",
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Get Detail Post",
          "enabled": true,
          "depends_on": "Doctor SignIn",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/get/detail/post",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{detail_post_payload}}",
          "expected": {
            "status_code": 200
          }
        },
        {
          "name": "Delete Post",
          "enabled": false,
          "depends_on": "Get Detail Post",
          "method": "POST",
          "url": "{{base_url}}/dc/api-post/v1/delete-post",
          "headers": {
            "ACIN-API-KEY": "{{api_key}}",
            "Authorization": "Bearer {{signin_access_token}}",
            "Content-Type": "application/json"
          },
          "json": "{{delete_post_payload}}",
          "expected": {
            "status_code": 200
          }
        }
      ]
    }
  ]
}
